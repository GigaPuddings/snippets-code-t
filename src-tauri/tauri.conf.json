{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "snippets-code",
  "version": "2.1.37",
  "identifier": "com.snippets-code.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/GigaPuddings/snippets-code-t/releases/latest/download/latest.json",
        "https://ghfast.top/github.com/GigaPuddings/snippets-code-t/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxNjFCNjVGMTY1OTc3NUUKUldSZWQxa1dYN1poNFpidktybDV2OGF4elpPK2IxUThGdi9hbGdaRjJ4akRqL2ptWjdQdXViYkwK"
    }
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob: asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline' asset: http://asset.localhost https://asset.localhost; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost https:; font-src 'self' data: asset: http://asset.localhost https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 asset: http://asset.localhost https://asset.localhost https://huggingface.co https://*.huggingface.co https://*.hf.co https://*.xethub.hf.co https://cdn.jsdelivr.net https://unpkg.com https://wallhaven.cc https://*.wallhaven.cc; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**/*",
            "$APPLOCALDATA/**/*",
            "$RESOURCE/**/*",
            "**/plugins/*/dist/**/*",
            "**/plugins/*/resources/transformers/**/*",
            "$HOME/**/*",
            "$DESKTOP/**/*",
            "$DOCUMENT/**/*",
            "$DOWNLOAD/**/*",
            "$PICTURE/**/*",
            "$VIDEO/**/*"
          ],
          "deny": [
            "$HOME/.ssh/**/*",
            "$HOME/.gnupg/**/*",
            "$HOME/**/.git/**/*",
            "$APPDATA/**/.git/**/*",
            "$APPLOCALDATA/**/.git/**/*"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2025 snippets-code",
    "category": "Utility",
    "shortDescription": "代码片段与知识资产工作台",
    "longDescription": "本地优先的代码片段与知识资产工作台，面向前端程序员设计，支持 Markdown 存储、智能搜索、Git 同步和插件扩展。",
    "publisher": "snippets-code",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "createUpdaterArtifacts": true
  }
}
