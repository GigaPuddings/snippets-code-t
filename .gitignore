# 忽略所有以 ~ 结尾的文件和文件夹
*~
.~*
~$*

# 忽略密钥文件
*.pem
*.key
*.key.pub

# 临时发布说明文件
.release-notes.tmp
release-notes.txt
RELEASE_NOTES_TEMP.md

# RapidOCR 本地二进制和模型较大，由 pnpm rapidocr:install 下载
src-tauri/resources/rapidocr/*
!src-tauri/resources/rapidocr/README.md

# FFmpeg 本地二进制较大，由 pnpm ffmpeg:install 下载
src-tauri/resources/ffmpeg/*
!src-tauri/resources/ffmpeg/README.md

# 插件 runtime 本地资源较大，应通过独立仓库 Release asset 分发，不进入主仓库
/docs/plugin-packages/*/resources/*
!/docs/plugin-packages/*/resources/README.md
