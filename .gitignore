# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dist-plugin-packages
!docs/plugin-packages/**/dist/
!docs/plugin-packages/**/dist/**
target
*.local
_tmp*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
.cursorignore
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
