{
  "schemaVersion": 1,
  "id": "local-launcher",
  "version": "2.0.8",
  "kind": "local",
  "name": {
    "i18nKey": "plugins.localLauncher.name",
    "fallback": "Apps and Bookmarks Launcher"
  },
  "description": {
    "i18nKey": "plugins.localLauncher.description",
    "fallback": "Local app and browser bookmark management, plus quick-launch search results."
  },
  "category": "search",
  "enabledByDefault": true,
  "capabilities": {
    "routeNames": [
      "Local"
    ],
    "settingsTabs": [
      "local"
    ],
    "searchSources": [
      "apps",
      "bookmarks"
    ]
  },
  "permissions": [
    "command:*"
  ],
  "compatibleAppVersion": ">=2.1.4",
  "entry": {
    "frontend": "dist/frontend.js",
    "styles": [
      "dist/assets/runtime-entry-CYgyi6kb.css"
    ]
  },
  "minAppVersion": "2.1.4",
  "repository": "https://github.com/GigaPuddings/snippets-code-plugin-local-launcher",
  "releaseUrl": "https://github.com/GigaPuddings/snippets-code-plugin-local-launcher/releases/tag/2.0.8"
}
