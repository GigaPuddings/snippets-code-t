  "permissions": [
    "command:*"
  ],
  "compatibleAppVersion": ">=2.0.2",
  "entry": {
    "frontend": "dist/frontend.js"
  },
  "minAppVersion": "1.5.6",
  "repository": "https://github.com/GigaPuddings/snippets-code-plugin-desktop-files",
  "releaseUrl": "https://github.com/GigaPuddings/snippets-code-plugin-desktop-files/releases/tag/2.0.2"
}
