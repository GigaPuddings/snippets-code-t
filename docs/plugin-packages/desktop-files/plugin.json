{
  "schemaVersion": 1,
  "id": "desktop-files",
  "version": "2.0.2",
  "kind": "local",
  "name": {
    "i18nKey": "plugins.desktopFiles.name",
    "fallback": "Desktop File Search"
  },
  "description": {
    "i18nKey": "plugins.desktopFiles.description",
    "fallback": "Index desktop files and show file results in global search."
