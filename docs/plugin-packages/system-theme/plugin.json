{
  "schemaVersion": 1,
  "id": "system-theme",
  "version": "1.5.6",
  "kind": "local",
  "name": {
    "i18nKey": "plugins.systemTheme.name",
    "fallback": "Auto Dark Mode"
  },
  "description": {
    "i18nKey": "plugins.systemTheme.description",
    "fallback": "Auto dark mode, sunrise/sunset scheduling, and system theme hotkey toggling."
  },
  "category": "appearance",
  "enabledByDefault": true,
  "capabilities": {
    "routeNames": [
      "DarkMode"
    ],
    "hotkeys": [
      "dark_mode"
    ]
  },
  "permissions": [
    "command:*"
  ],
  "compatibleAppVersion": ">=1.5.6",
  "entry": {
    "frontend": "dist/frontend.js",
    "styles": [
      "dist/assets/index-fTz62839.css",
      "dist/assets/TitlebarGitStatus-BFSOFKGh.css"
    ]
  },
  "minAppVersion": "1.5.6",
  "repository": "https://github.com/GigaPuddings/snippets-code-plugin-system-theme",
  "releaseUrl": "https://github.com/GigaPuddings/snippets-code-plugin-system-theme/releases/tag/1.5.6"
}
