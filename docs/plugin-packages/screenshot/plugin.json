{
  "schemaVersion": 1,
  "id": "screenshot",
  "version": "1.5.6",
  "kind": "local",
  "name": {
    "i18nKey": "plugins.screenshot.name",
    "fallback": "Screenshot and OCR"
  },
  "description": {
    "i18nKey": "plugins.screenshot.description",
    "fallback": "Screenshot annotation, color picker, pin windows, OCR, and screenshot translation."
  },
  "category": "capture",
  "enabledByDefault": true,
  "capabilities": {
    "routeNames": [
      "Screenshot",
      "Pin"
    ],
    "hotkeys": [
      "screenshot"
    ]
  },
  "resources": {
    "hintKey": "plugins.screenshot.resourceHint",
    "bundled": false
  },
  "permissions": [
    "command:*"
  ],
  "dependencies": [
    "screenshot-rapidocr"
  ],
  "compatibleAppVersion": ">=1.5.6",
  "entry": {
    "frontend": "dist/frontend.js",
    "styles": [
      "dist/assets/index-CVVd-qCm.css",
      "dist/assets/index-D8nqDbCw.css"
    ]
  },
  "minAppVersion": "1.5.6",
  "repository": "https://github.com/GigaPuddings/snippets-code-plugin-screenshot",
  "releaseUrl": "https://github.com/GigaPuddings/snippets-code-plugin-screenshot/releases/tag/1.5.6"
}
