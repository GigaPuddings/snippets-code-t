{
  "schemaVersion": 1,
  "id": "screenshot",
  "version": "2.0.29",
  "kind": "local",
  "name": {
    "i18nKey": "plugins.screenshot.name",
    "fallback": "Screenshot and OCR"
  },
  "description": {
    "i18nKey": "plugins.screenshot.description",
    "fallback": "Screenshot annotation, color picker, pin windows, OCR, and screenshot translation."
  },
  "category": "capture",
  "enabledByDefault": true,
  "capabilities": {
    "routeNames": [
      "Screenshot",
      "Pin"
    ],
    "hotkeys": [
      "screenshot"
    ],
    "trayItems": [
      "screenshot"
    ]
  },
  "resources": {
    "hintKey": "plugins.screenshot.resourceHint",
    "bundled": false
  },
  "permissions": [
    "command:*"
  ],
  "dependencies": [
    "screenshot-rapidocr",
    "translation"
  ],
  "compatibleAppVersion": ">=2.1.9",
  "entry": {
    "frontend": "dist/frontend.js",
    "styles": [
      "dist/assets/runtime-entry-BCItY2Fy.css"
    ]
  },
  "minAppVersion": "2.1.9",
  "repository": "https://github.com/GigaPuddings/snippets-code-plugin-screenshot",
  "releaseUrl": "https://github.com/GigaPuddings/snippets-code-plugin-screenshot/releases/tag/2.0.29"
}
